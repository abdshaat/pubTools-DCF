# --- Secrets: never commit API keys or credentials ---
# The FMP API key is read only from the FMP_API_KEY environment variable
# (see app/providers/fmp.py) and must never be written to a tracked file.
.env
.env.*
*.env
!.env.example
secrets.*
*.secret
*.secrets
credentials.json
credentials.*
*.pem
*.key
*.p12
*.pfx
.netrc

# --- Cached provider data (may embed request context) ---
data/

# --- Python ---
.venv/
.venv313/
.venv-store-broken/
venv/
env/
ENV/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
pip-wheel-metadata/
__pypackages__/
build/
dist/
wheels/
site/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
junit*.xml
test-results/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pyright/
.pyre/
.pytype/
.ipynb_checkpoints/

# --- Node / Vercel local tooling ---
.vercel/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Supabase CLI local state (migrations/ itself stays tracked) ---
supabase/.branches/
supabase/.cache/
supabase/.temp/
supabase/.env
supabase/.env.*

# --- Logs, temporary files, and local backups ---
*.log
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# --- Local notes / editor ---
# Ignore Markdown planning/instruction files. Keep the public repository README.
*.md
*.MD
!README.md
!README.MD
.claude/
.vscode/
.idea/
.vs/
.DS_Store
Thumbs.db
Desktop.ini
