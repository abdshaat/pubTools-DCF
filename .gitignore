# --- Secrets: never commit API keys or credentials ---
# The FMP API key is read only from the FMP_API_KEY environment variable
# (see app/providers/fmp.py) and must never be written to a tracked file.
.env
.env.*
*.env
!.env.example
secrets.*
*.secret
*.secrets
credentials.json
credentials.*
*.pem
*.key
*.p12
*.pfx
.netrc

# --- Cached provider data (may embed request context) ---
data/

# --- Python ---
.venv/
.venv313/
.venv-store-broken/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
.mypy_cache/
.ruff_cache/

# --- Local notes / editor ---
# Ignore Markdown planning/instruction files. Keep the public repository README.
*.md
*.MD
!README.md
!README.MD
.claude/
.vercel/
.vscode/
.idea/
.DS_Store
Thumbs.db
