# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must never be committed.

# Financial Modeling Prep API key — get one at
# https://site.financialmodelingprep.com/developer/docs
# The app reads this from the environment (app/providers/fmp.py).
FMP_API_KEY=your-key-here

# Supabase-backed production auth/quota/metering.
# Set both in Vercel server-side environment variables. Never expose the
# service-role key to browser JavaScript.
# When both are present, valuation endpoints require X-API-Key and use
# Supabase for per-key daily quotas and usage records.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional but recommended before issuing production keys. When set, newly
# created or rotated API keys are stored as peppered HMAC-SHA256 hashes.
# Keep this stable and secret; changing it invalidates peppered keys.
API_KEY_HASH_PEPPER=replace-with-a-long-random-secret

# Public base URL of THIS deployment (no trailing slash). Used to build the
# GitHub OAuth redirect (`{PUBLIC_BASE_URL}/v1/auth/callback`) and the
# post-login/error redirect back to the site. Must exactly match a URL in
# Supabase's Authentication > URL Configuration > Redirect URLs allowlist.
# Defaults to http://127.0.0.1:8000 for local development.
PUBLIC_BASE_URL=http://127.0.0.1:8000
